interface ScheduleSession {
  day_of_week: string;
  slot_numbers: number[];
}

// Schedule entry type
interface ScheduleEntry {
  id: string;
  course_code: string;
  course_name: string;
  instructor: string;
  classroom: string;
  color: string;
}

// Course for edit/delete
interface CourseInfo {
  id: string;
  course_code: string;
  course_name: string;
  instructor: string;
  classroom: string;
  class_level: number;
  max_capacity: number;
}

