# Server Configuration
ENVIRONMENT=development
PORT=8081

# Database Configuration
DB_URL=postgres://postgres:postgres@localhost:5432/mydreamcampus_auth?sslmode=disable

# RabbitMQ Configuration
RABBITMQ_URL=amqp://rabbitmq:rabbitmq@localhost:5672/

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=15
JWT_REFRESH_TOKEN_EXPIRY=24

# Admin Configuration
ADMIN_EMAIL=admin@university.edu.tr
ADMIN_INITIAL_PASSWORD=Admin123!
