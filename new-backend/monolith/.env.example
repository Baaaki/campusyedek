# MyDreamCampus monolith config — copy to `.env` and adjust.

# Server
ENVIRONMENT=development
PORT=8080

# Database — single instance, schema-per-module (plan section 4.1).
DB_URL=postgres://postgres:postgres@localhost:5432/mydreamcampus?sslmode=disable

# RabbitMQ
RABBITMQ_URL=amqp://rabbitmq:rabbitmq@localhost:5672/

# Redis (rate limiting + auth blacklist)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=changeme_redis_secret
REDIS_DB=0

# JWT (HS256). MUST be replaced in production.
JWT_SECRET=change-this-secret-in-production
JWT_ACCESS_TOKEN_EXPIRY=600
JWT_REFRESH_TOKEN_EXPIRY=24

# Initial admin user
ADMIN_EMAIL=admin@university.edu.tr
ADMIN_INITIAL_PASSWORD=Admin123!

# Outbox relay (plan section 5.5.2 selection A)
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_RETRIES=5

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_IP_LIMIT=100
RATE_LIMIT_IP_WINDOW_SECS=60
RATE_LIMIT_USER_LIMIT=200
RATE_LIMIT_USER_WINDOW_SECS=60
RATE_LIMIT_LOGIN_LIMIT=20
RATE_LIMIT_LOGIN_WINDOW_SECS=60
RATE_LIMIT_REFRESH_LIMIT=10
RATE_LIMIT_REFRESH_WINDOW_SECS=60
RATE_LIMIT_PASSWORD_LIMIT=3
RATE_LIMIT_PASSWORD_WINDOW_SECS=300

# Timeouts
REQUEST_TIMEOUT_SECONDS=10
SHUTDOWN_TIMEOUT_SECONDS=30
ACCOUNT_LOCK_DURATION_MINUTES=30
CLEANUP_SCHEDULER_INTERVAL_HOURS=1
PROCESSED_EVENTS_RETENTION_DAYS=30

# Frontend SPA serving (production only — dev uses Vite proxy, plan section 7.2)
FRONTEND_STATIC_ENABLED=false
FRONTEND_STATIC_DIR=./frontend_dist
