# Backend API base URL (reached via Traefik gateway).
# Must start with EXPO_PUBLIC_ to be bundled into the app.
#
# iOS simulator:    http://localhost/api
# Android emulator: http://10.0.2.2/api
# Physical device:  http://<your-computer-lan-ip>/api   (e.g. http://192.168.1.42/api)
EXPO_PUBLIC_API_URL=http://localhost/api
