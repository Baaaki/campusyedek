# Environment
ENVIRONMENT=development
PORT=8008

# Infrastructure connections (from infrastructure/docker-compose.yml)
DB_URL=postgres://postgres:postgres@localhost:5439/mydreamcampus_meal?sslmode=disable
RABBITMQ_URL=amqp://rabbitmq:rabbitmq@localhost:5672/
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security (CHANGE IN PRODUCTION!)
JWT_SECRET=your-secret-key-change-in-production

# QR Code Secret (CHANGE IN PRODUCTION!)
QR_SECRET=your-random-32-char-secret-here-change-this

# Payment Service
PAYMENT_SERVICE_URL=http://localhost:8004

# Reservation Settings
RESERVATION_TIMEOUT_MINUTES=15
MEAL_PRICE_TRY=15.00

# Meal Time Windows (UTC+3)
LUNCH_START_HOUR=11
LUNCH_END_HOUR=13
DINNER_START_HOUR=16
DINNER_END_HOUR=19

# Outbox Settings
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=5

# Timezone
TZ=Europe/Istanbul
